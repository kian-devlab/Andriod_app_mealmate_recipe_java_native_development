<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="10dp">

    <!-- Grocery Item Name -->
    <TextView
        android:id="@+id/tv_grocery_item"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ingredient Name"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/cb_grocery_item"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/cb_grocery_item" />

    <!-- Checkbox to mark as purchased -->
    <CheckBox
        android:id="@+id/cb_grocery_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Share Grocery via SMS -->
    <TextView
        android:id="@+id/tv_share_grocery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share via SMS"
        android:textColor="@android:color/holo_blue_dark"
        app:layout_constraintTop_toBottomOf="@id/tv_grocery_item"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
